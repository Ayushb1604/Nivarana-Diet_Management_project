# =============================================================================
# NIVARANA Platform — Environment Variables Template  (DEPLOY-01 fix)
# =============================================================================
# Copy this file to `.env.local` for local development.
# In production, set these via your hosting platform's environment panel.
# ⚠️  NEVER commit a file containing real secret values to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Full PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Alternatively, individual connection parts (used by some ORMs/tools):
# PGHOST=
# PGPORT=5432
# PGUSER=
# PGPASSWORD=
# PGDATABASE=

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
# A long, random, secret string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ⚠️  Required in production — the server will refuse to start without this.
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
# Set by your deployment platform — do NOT hardcode here.
# Values: development | production | test
# NODE_ENV=production

# -----------------------------------------------------------------------------
# Application URL  (used for password-reset email links)
# -----------------------------------------------------------------------------
APP_URL=https://your-app-domain.com

# -----------------------------------------------------------------------------
# OpenAI  (required for AI Meal Plan generation)
# -----------------------------------------------------------------------------
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Resend  (required for password-reset emails)
# -----------------------------------------------------------------------------
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# Admin Access
# -----------------------------------------------------------------------------
# The email address that will be granted admin privileges.
# If unset, the first registered user becomes admin (development convenience only).
ADMIN_EMAIL=admin@yourdomain.com
